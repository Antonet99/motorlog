{
  "name": "motorlog",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:emulator": "vite --mode emulator --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "preview:deploy": "npm run build && npx firebase-tools hosting:channel:deploy preview --expires 30d",
    "emulators:start": "npx firebase-tools emulators:start --project motorlog-qbk6 --only auth,firestore",
    "seed:demo": "node scripts/seed-demo.mjs",
    "local:start": "npx firebase-tools emulators:exec --project motorlog-qbk6 --only auth,firestore \"node scripts/seed-demo.mjs && npx vite --mode emulator --host 0.0.0.0\"",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "firebase": "^12.11.0",
    "lucide-react": "^0.546.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "firebase-admin": "^13.4.0",
    "firebase-tools": "^15.11.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
